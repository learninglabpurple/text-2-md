# Required — Bot token (xoxb-...) from OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-

# Required — App-level token (xapp-...) from Socket Mode settings
SLACK_APP_TOKEN=xapp-

# Optional — Emoji that triggers conversion (without colons, default: page_facing_up)
CONVERT_EMOJI=dog-of-wisdom-2

# Optional — Anthropic API key for LLM-based markdown cleanup (skipped if not set)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Split output files at this character limit (e.g. 100000 for HackMD).
# Files are split at heading/section boundaries. Naming: filename_part1of3.md
# If not set, output is a single file regardless of length.
# MAX_OUTPUT_CHARS=100000

# Optional — Customize what counts as front/back matter for boundary detection.
# If not set, broad defaults are used. Override these for specialized corpora.
# FRONT_MATTER_DEFINITION=Everything before the first chapter or section of the primary text: title pages, copyright pages, tables of contents, editor/translator introductions, prefaces, dedications, forewords, bibliographic notes, acknowledgments, lists of abbreviations
# BACK_MATTER_DEFINITION=Everything after the last chapter or section of the primary text: appendices, indexes, glossaries, endnotes, bibliographies, editorial afterwords, colophons, about the author sections
